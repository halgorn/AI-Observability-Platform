# Copy to .env and fill in. Never commit .env.

# --- Auth ---
INGEST_API_SECRET=change-me-32-bytes-base64

# --- Storage ---
POSTGRES_DSN=postgres://user:pass@localhost:5432/ai_obs
REDIS_URL=redis://localhost:6379/0
KAFKA_BROKERS=localhost:9092
S3_BUCKET=ai-obs-artifacts
S3_REGION=us-east-1

# --- Spec ---
SPEC_ROOT=/app/specs

# --- Observability ---
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_RELEASE=ingest-api@0.1.0
SENTRY_TRACES_SAMPLE_RATE=0.1

OTEL_SERVICE_NAME=ingest-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_EXPORTER=otlp

# --- App ---
PORT=8000
WEB_CONCURRENCY=2
LOG_LEVEL=info
PII_MODE=redact
DOCS_ENABLED=1
