{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-obs.local/schemas/run.v1.json",
  "title": "Run",
  "type": "object",
  "required": ["run_id", "agent", "status", "started_at"],
  "properties": {
    "run_id":         { "type": "string", "format": "uuid" },
    "thread_id":      { "type": ["string", "null"] },
    "agent":          { "type": "string", "pattern": "^[a-z0-9_-]{1,64}$" },
    "status":         { "enum": ["running","succeeded","failed","timeout","cancelled","replaying"] },
    "started_at":     { "type": "string", "format": "date-time" },
    "ended_at":       { "type": ["string", "null"], "format": "date-time" },
    "duration_ms":    { "type": ["integer", "null"], "minimum": 0 },
    "total_steps":    { "type": ["integer", "null"], "minimum": 0 },
    "total_tokens":   { "type": ["integer", "null"], "minimum": 0 },
    "total_cost_usd": { "type": ["number", "null"], "minimum": 0 },
    "input_hash":     { "type": ["string", "null"] },
    "output_hash":    { "type": ["string", "null"] },
    "prompt_version": { "type": ["string", "null"] },
    "parent_run_id":  { "type": ["string", "null"], "format": "uuid" },
    "tags":           { "type": "object", "additionalProperties": { "type": "string" } }
  }
}
