{
  "uid": "ai-obs-agent-overview",
  "title": "Agent Overview",
  "tags": ["ai-observability"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "agent",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(ai_obs_events_total, agent)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "label": "Agent"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Events / min (by agent)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (agent) (rate(ai_obs_events_total{agent=~\"$agent\",status=\"accepted\"}[5m]) * 60)",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"fillOpacity": 10}}
      }
    },
    {
      "id": 2,
      "title": "Error rate % (by agent)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * sum by (agent) (rate(ai_obs_events_total{agent=~\"$agent\",status!=\"accepted\"}[5m])) / sum by (agent) (rate(ai_obs_events_total{agent=~\"$agent\"}[5m]))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 5, "color": "yellow"}, {"value": 10, "color": "red"}]}}
      }
    },
    {
      "id": 3,
      "title": "Agent event ranking (last 24h)",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "topk(10, sum by (agent) (increase(ai_obs_events_total{status=\"accepted\"}[24h])))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "title": "Event type breakdown",
      "type": "piechart",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (event_type) (increase(ai_obs_events_total{agent=~\"$agent\",status=\"accepted\"}[24h]))",
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total accepted events (24h)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 16, "w": 6, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(ai_obs_events_total{agent=~\"$agent\",status=\"accepted\"}[24h]))",
          "legendFormat": "accepted"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 6,
      "title": "Total rejected events (24h)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 16, "w": 6, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(ai_obs_events_total{agent=~\"$agent\",status!=\"accepted\"}[24h]))",
          "legendFormat": "rejected"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "red"}}}
    },
    {
      "id": 7,
      "title": "Ingest HTTP p95 latency",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 4},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=\"/v1/events\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95 ms"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    }
  ],
  "schemaVersion": 36
}
